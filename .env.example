# Sanctum AutoQC — environment template.
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# Get these from: Supabase dashboard → Project Settings → API / Database.

SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_PROJECT_REF=<your-project-ref>
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-side only; full DB access
SUPABASE_DB_PASSWORD=<database-password>
